BOT_TOKEN=
CHANNEL_ID=
ADMIN_CHAT_ID=

# AliExpress Affiliate API credentials
# Get these from https://openservice.aliexpress.com
ALIEXPRESS_API_KEY=
ALIEXPRESS_API_SECRET=
ALIEXPRESS_TRACKING_ID=
ALIEXPRESS_LANGUAGE=EN
ALIEXPRESS_CURRENCY=USD

# Optional — filter products by keywords or categories
ALIEXPRESS_KEYWORDS=
ALIEXPRESS_CATEGORY_IDS=
ALIEXPRESS_MIN_SALE_PRICE=
ALIEXPRESS_MAX_SALE_PRICE=
ALIEXPRESS_SHIP_TO_COUNTRY=

# Redis connection string (e.g. redis://default:password@upstash-host:6379)
# Used for deduplication — prevents posting the same deal twice.
# Get a free instance at https://console.upstash.com
REDIS_URL=

FETCH_INTERVAL_HOURS=6
MIN_DISCOUNT=40

# Pagination — cycle through pages to discover more products
MAX_PAGES=5

# Strategy: "hot" (Hot Products API — trending, recommended), "classic" (old behavior)
FETCH_STRATEGY=hot

# Scoring weights — controls what makes a "good" deal
# Higher weight_volume = prioritize popular products
# Higher weight_discount = prioritize big discounts
# Higher weight_rating = prioritize highly rated products
SCORE_WEIGHT_VOLUME=0.4
SCORE_WEIGHT_DISCOUNT=0.3
SCORE_WEIGHT_RATING=0.3

# Number of top-scored deals to publish per cycle
TOP_DEALS=10

# Health check server port (Railway sets PORT automatically)
PORT=8080
